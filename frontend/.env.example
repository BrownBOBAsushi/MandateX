# ── Backend ──────────────────────────────────────────────────────────────────
# URL of the FastAPI backend (Railway or local).
# Frontend runs on port 3001 (npm run dev) to avoid conflict with the
# TS demo server (npm run coinbase:server) which uses port 3000.
NEXT_PUBLIC_API_URL=https://mandatex-backend-desmond-chyes-projects.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL — Supabase → Project Settings → API → Project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role key (secret, server-side only — never expose to the browser).
# Supabase → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── MCP Server ────────────────────────────────────────────────────────────────
# Static bearer token that Claude.ai presents to authenticate against /api/mcp.
# Generate any strong random string — must match what you register in Claude.ai.
MCP_BEARER_TOKEN=
