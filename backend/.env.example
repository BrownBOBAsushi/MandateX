# Solana devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=
# Base58 encoded private key for mandate writes AND x402 payments.
# Generate: solana-keygen new --outfile wallet.json
# Then extract base58 key from wallet.json (it's the array in the file).

# x402 vendor endpoint — the TS reference demo server acts as the vendor.
# Keep `npm run coinbase:server` running in a separate terminal.
X402_VENDOR_URL=http://localhost:3000

# Coinbase facilitator — used by the TS demo server, not called directly by x402.py.
X402_FACILITATOR_URL=https://facilitator.coinbase.com
